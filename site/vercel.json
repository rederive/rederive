{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(ClaudeBot|Claude-User|Claude-Web|claude-code|Claude-Code|anthropic|GPTBot|ChatGPT-User|OAI-SearchBot|PerplexityBot|Perplexity-User|Devin|Cursor).*"
        }
      ],
      "destination": "/llms.txt",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(llms.txt|prompt.md)",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "X-Agent-Note", "value": "Full agent workflow at /prompt.md; index at /llms.txt" }
      ]
    }
  ]
}
