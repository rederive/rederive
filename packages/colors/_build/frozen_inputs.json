{
  "unit": "strip",
  "exportName": "strip",
  "importPath": "/tmp/colors.js/lib/colors.js",
  "vectors": [
    {
      "name": "plain_text",
      "args": [
        "hello world"
      ],
      "expected": "hello world"
    },
    {
      "name": "single_sgr_red",
      "args": [
        "\u001b[31mhi\u001b[39m"
      ],
      "expected": "hi"
    },
    {
      "name": "bold",
      "args": [
        "\u001b[1mhi\u001b[22m"
      ],
      "expected": "hi"
    },
    {
      "name": "mid_string",
      "args": [
        "a\u001b[32mb\u001b[39mc"
      ],
      "expected": "abc"
    },
    {
      "name": "stacked_codes",
      "args": [
        "\u001b[31m\u001b[1mhi\u001b[22m\u001b[39m"
      ],
      "expected": "hi"
    },
    {
      "name": "only_codes",
      "args": [
        "\u001b[31m\u001b[39m"
      ],
      "expected": ""
    },
    {
      "name": "trailing_reset",
      "args": [
        "text\u001b[0m"
      ],
      "expected": "text"
    },
    {
      "name": "empty",
      "args": [
        ""
      ],
      "expected": ""
    },
    {
      "name": "number_coerced",
      "args": [
        42
      ],
      "expected": "42"
    },
    {
      "name": "high_param_bg",
      "args": [
        "\u001b[100mhi\u001b[49m"
      ],
      "expected": "hi"
    }
  ]
}