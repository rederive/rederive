{
  "mode": "vectors",
  "exportName": "paramsHaveRequestBody",
  "unit": "paramsHaveRequestBody",
  "vectors": [
    {
      "name": "has_body",
      "args": [
        {
          "body": "hello"
        }
      ],
      "expected": "hello"
    },
    {
      "name": "empty",
      "args": [
        {}
      ]
    },
    {
      "name": "stream",
      "args": [
        {
          "requestBodyStream": "s"
        }
      ],
      "expected": "s"
    },
    {
      "name": "json_bool_true",
      "args": [
        {
          "json": true
        }
      ]
    },
    {
      "name": "json_object",
      "args": [
        {
          "json": {
            "a": 1
          }
        }
      ],
      "expected": true
    },
    {
      "name": "multipart",
      "args": [
        {
          "multipart": [
            {
              "body": "x"
            }
          ]
        }
      ],
      "expected": [
        {
          "body": "x"
        }
      ]
    }
  ],
  "heldout": [
    {
      "name": "ho_body_zero",
      "args": [
        {
          "body": 0
        }
      ]
    },
    {
      "name": "ho_body_empty",
      "args": [
        {
          "body": ""
        }
      ]
    },
    {
      "name": "ho_json_false",
      "args": [
        {
          "json": false
        }
      ]
    },
    {
      "name": "ho_json_string",
      "args": [
        {
          "json": "str"
        }
      ],
      "expected": true
    },
    {
      "name": "ho_multipart_empty",
      "args": [
        {
          "multipart": []
        }
      ],
      "expected": []
    },
    {
      "name": "ho_body_wins",
      "args": [
        {
          "body": "b",
          "json": {
            "x": 1
          }
        }
      ],
      "expected": "b"
    },
    {
      "name": "ho_json_zero",
      "args": [
        {
          "json": 0
        }
      ]
    }
  ]
}
