{
  "name": "rederive",
  "version": "0.3.0",
  "description": "The trust-nothing package manager. A rederive package ships its CONTRACT (spec + held-out oracle), not trusted bytes — verify the shipped code against it, or re-derive it locally from the spec.",
  "keywords": [
    "supply-chain",
    "verification",
    "package-manager",
    "trust",
    "sir",
    "held-out-oracle",
    "verified-recompose"
  ],
  "homepage": "https://rederive.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rederive/rederive.git"
  },
  "bugs": "https://github.com/rederive/rederive/issues",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "rdv": "dist/cli.cjs",
    "rederive": "dist/cli.cjs"
  },
  "files": [
    "dist/",
    "cli/",
    "README.md",
    "LICENSE",
    "STEWARDSHIP.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "esbuild cli/rdv.mts --bundle --platform=node --format=cjs --target=node18 --outfile=dist/cli.cjs --banner:js='#!/usr/bin/env node'",
    "prepublishOnly": "npm run build",
    "rdv": "tsx cli/rdv.mts",
    "check": "tsx cli/rdv.mts check packages/colors",
    "vis": "tsx cli/rdv.mts vis packages/colors"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0"
  }
}
