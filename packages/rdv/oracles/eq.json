{
  "mode": "vectors",
  "exportName": "eq",
  "unit": "eq",
  "vectors": [
    {
      "name": "int_equal",
      "args": [
        1,
        1
      ],
      "expected": true
    },
    {
      "name": "int_unequal",
      "args": [
        1,
        2
      ],
      "expected": false
    },
    {
      "name": "str_equal",
      "args": [
        "abc",
        "abc"
      ],
      "expected": true
    },
    {
      "name": "coerce_reject",
      "args": [
        1,
        "1"
      ],
      "expected": false
    },
    {
      "name": "array_equal",
      "args": [
        [
          1,
          2,
          3
        ],
        [
          1,
          2,
          3
        ]
      ],
      "expected": true
    },
    {
      "name": "nested_equal",
      "args": [
        {
          "a": [
            1
          ]
        },
        {
          "a": [
            1
          ]
        }
      ],
      "expected": true
    },
    {
      "name": "empty_arrays",
      "args": [
        [],
        []
      ],
      "expected": true
    },
    {
      "name": "bool_equal",
      "args": [
        true,
        true
      ],
      "expected": true
    }
  ],
  "heldout": [
    {
      "name": "ho_array_reorder",
      "args": [
        [
          1,
          2
        ],
        [
          2,
          1
        ]
      ],
      "expected": false
    },
    {
      "name": "ho_objkey_order",
      "args": [
        {
          "a": 1,
          "b": 2
        },
        {
          "b": 2,
          "a": 1
        }
      ],
      "expected": false
    },
    {
      "name": "ho_null_vs_zero",
      "args": [
        null,
        0
      ],
      "expected": false
    },
    {
      "name": "ho_arr_vs_obj",
      "args": [
        [],
        {}
      ],
      "expected": false
    },
    {
      "name": "ho_zero_vs_false",
      "args": [
        0,
        false
      ],
      "expected": false
    },
    {
      "name": "ho_emptystr_vs_emptyarr",
      "args": [
        "",
        []
      ],
      "expected": false
    },
    {
      "name": "ho_deep_nonfirst_mismatch",
      "args": [
        {
          "x": 1,
          "y": [
            1,
            2,
            3
          ]
        },
        {
          "x": 1,
          "y": [
            1,
            2,
            4
          ]
        }
      ],
      "expected": false
    },
    {
      "name": "ho_str_equal2",
      "args": [
        "hello",
        "hello"
      ],
      "expected": true
    },
    {
      "name": "ho_nested_obj_equal",
      "args": [
        {
          "a": {
            "b": 2
          }
        },
        {
          "a": {
            "b": 2
          }
        }
      ],
      "expected": true
    }
  ]
}
